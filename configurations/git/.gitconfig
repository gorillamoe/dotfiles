[user]
  name = Marco Kellershoff
  email = marco@mistweaverco.com
  signingkey = B343EA40D2D7A7AC

[credential]
  helper = gnome-keyring

[commit]
  gpgsign = true

[color]
  status = auto

[color "status"]
  added = green
  changed = blue
  untracked = magenta
  deleted = red

[alias]
  # Git stash pop, but shorter
  unstash = stash pop
  # Clean branches
  cb = "!git-branch-cleaner.sh"
  # just an alias for rebase --continue
  reco = rebase --continue
  # adds all changes, including deletions
  wip = commit -m "wip" -a
  # reset to x commits back (where x is the first argument),
  # but keep the changes in the working directory
  undo = "!f() { if [[ -z $1 ]]; then echo 'Undo count is required!'; else git reset --soft \"HEAD~$1\";git log -1;git status; fi; }; f"
  # Adds all changes, including deletions, amends, but opens editor for changing commit message
  amend = commit --amend --reset-author -a
  # like am, but keep the author info
  amend-keep = commit --amend -a
  # get latest tag
  # matches tags like v1.2.3
  lt = "!git describe --tags --match 'v[0-9]*.[0-9]*.[0-9]*' --abbrev=0 \"$(git rev-list --tags='v[0-9]*.[0-9]*.[0-9]*' --max-count=1 | tail -n 1)\""
  # get previous tag before the latest tag
  # matches tags like v1.2.3
  pt = "!git describe --tags --match 'v[0-9]*.[0-9]*.[0-9]*' --abbrev=0 \"$(git rev-list --tags='v[0-9]*.[0-9]*.[0-9]*' --max-count=2 | tail -n 1)\""
  # release - create a new tag and push it
  # usage: git release <"patch"|"minor"|"major"> [<create-annotated-tag-truthish-value>]
  release = "!git-release.sh \"$1\" \"$2\""
  aa = add -A
  # git status
  st = status
  # git branch
  b = branch
  # git co - used to checkout branches or files
  co = checkout
  # git sw is switch - used to switch branches
  sw = switch
  # git checkout -b
  cob = checkout -b
  # merge graph
  tree = log --graph --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold cyan)%aD%C(reset) %C(bold green)(%ar)%C(reset)%C(bold yellow)%d%C(reset)%n''          %C(white)%s%C(reset) %C(dim white)- %an (%G?)%C(reset)'
  # git commit
  ci = commit
  # List commits showing changed files is invoked with git ll and looks like
  ll = log --pretty=format:"%C(yellow)%h%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --numstat
  # List with no colors if you need to chain the out put with Unix pipes:
  lnc = log --pretty=format:"%h\\ %s\\ [%cn]"
  # List oneline commits showing dates
  lds = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=local --date=format:'%Y-%m-%d %H:%M:%S'
  # List oneline commits showing relative dates
  ld = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative
  # see all the commits related to a file,
  # with the diff of the changes
  # Optionally filter by a search term for file names
  # like `git filelog-diff README` or `git fl-diff src/
  filelog-diff = log -u
  fl-diff = log -u
  # see all the commits related to a file,
  # without the diff of the changes.
  # Optionally filter by a search term for file names
  # like `git filelog README` or `git fl src/`
  filelog = log --stat
  fl = log --stat
  # Show diff
  d = diff
  # Show a cached diff:
  dc = diff --cached
  # git lds --show-signature with optional limit ( like `git log -3`)
  # Just do `git sig` for the most recent one or `git log 7` for the 7
  # most recent ones.
  sig = "!f() { if [[ ! -z $1 ]]; then git lds --show-signature -$1; else git lds --show-signature -1; fi; }; f"
  # This is what git blame should look like in the first place
  # bbl stands for better blame
  bbl = "!f() { git blame --root -w -M -C -c --porcelain \"$@\" | awk 'BEGIN {OFS=\"\\t\"; H=\"\\033[33m\"; A=\"\\033[36m\"; D=\"\\033[34m\"; R=\"\\033[0m\"} /^([0-9a-f]{40})/ {commit=substr($1, 1, 12)} /^author / {author=substr($0, 8)} /^author-time / {date=strftime(\"%Y-%m-%d\", $2)} /^\t/ {print H commit R, A author R, D date R, substr($0, 2)}'; }; f"
  # shorthand for git add -p (patch)
  yy = add -p
  # shorthands for getting git root
  root = rev-parse --show-toplevel

[push]
  default = simple
  autoSetupRemote = true

[pull]
  default = simple
  rebase = true

[merge]
  conflictstyle = diff3
  tool = diffconflicts

[pager]
  diff = false
  log = false

[core]
  whitespace = -blank-at-eof

[init]
  defaultBranch = main

[mergetool]
  keepBackup = false

[mergetool "diffconflicts"]
  cmd = nvim -c DiffConflicts \"$MERGED\" \"$BASE\" \"$LOCAL\" \"$REMOTE\"
  trustExitCode = true

[includeIf "gitdir:~/projects/work/"]
  path = ~/projects/work/.gitconfig
